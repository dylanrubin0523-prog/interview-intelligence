# Copy to .env.local and fill in real values. Never commit .env.local.
# See docs/ARCHITECTURE.md for how these are used.

# Supabase project settings (Project Settings -> API in the Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Optional. Reserved for a future trusted admin/service-role Supabase client
# (not built yet) that bypasses RLS. Leave unset until that client exists.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Optional. Error tracking (see instrumentation.ts / instrumentation-client.ts).
# With this unset, Sentry's SDK no-ops -- the app builds and runs normally.
# To enable it later:
#   1. Create a project at sentry.io (Next.js platform).
#   2. Copy its DSN (Project Settings -> Client Keys (DSN)) here and in Vercel's
#      environment variables. A DSN is not a secret and is safe in client code.
#   3. Visit /sentry-example-page to trigger a client + server test error and
#      confirm both appear in the Sentry project.
# Source-map upload (readable stack traces) needs SENTRY_AUTH_TOKEN,
# SENTRY_ORG, and SENTRY_PROJECT in addition to the DSN -- not wired up yet,
# deferred until a real project exists (see PR for issue #7).
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
