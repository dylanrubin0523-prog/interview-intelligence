# Copy to .env.local and fill in real values. Never commit .env.local.
# See docs/ARCHITECTURE.md for how these are used.

# Supabase project settings (Project Settings -> API in the Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Optional. Reserved for a future trusted admin/service-role Supabase client
# (not built yet) that bypasses RLS. Leave unset until that client exists.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key
